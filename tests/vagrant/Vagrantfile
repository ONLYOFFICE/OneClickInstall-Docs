Vagrant.configure("2") do |config|
    config.vm.box = "#{ENV['DISTR']}/#{ENV['OS']}"

    config.vm.provider "virtualbox" do |v|
             v.customize ["modifyvm", :id, "--memory", "#{ENV['RAM']}"] #<= total RAM.
             v.customize ["modifyvm", :id, "--cpus", "#{ENV['CPU']}"] #<= total CPU.
             v.customize ["modifyvm", :id, "--ioapic", "on"]
    end

    config.vm.define 'ubuntu'

    config.vm.hostname = "host4test"

    if ENV['TEST_CASE'] != '--production-install'
    name: "debug-tmp-docs-before-file",
      inline: <<-'SHELL'
        echo "=== DEBUG BEFORE FILE PROVISIONER ==="
        echo "whoami: $(whoami)"
        echo "id: $(id)"
        echo "--- ls -ld /tmp ---"
        ls -ld /tmp || echo "no /tmp"
        echo "--- ls -ld /tmp/docs ---"
        ls -ld /tmp/docs || echo "no /tmp/docs"
        echo "--- stat /tmp/docs ---"
        stat /tmp/docs 2>/dev/null || echo "stat: no /tmp/docs"
        echo "==============================="
      SHELL
    # if ENV['OS'] == 'docs-centos10'
    #   config.vm.provision "shell",
    #     inline: <<-SHELL
    #       sudo rm -rf /tmp/docs
    #       sudo mkdir -p /tmp/docs
    #       sudo chmod 1777 /tmp/docs
    #       sudo chown vagrant:vagrant /tmp/docs
    #     SHELL
    # end
       config.vm.provision "file", source: "../../../OneClickInstall-Docs/.", destination: "/tmp/docs/"
    end

    config.vm.provision "shell", path: './install.sh', :args => "#{ENV['DOWNLOAD_SCRIPT']} #{ENV['VER']} #{ENV['TEST_REPO']} #{ENV['ARGUMENTS']}"

    # Prevent SharedFoldersEnableSymlinksCreate errors
    config.vm.synced_folder ".", "/vagrant", disabled: true
end

